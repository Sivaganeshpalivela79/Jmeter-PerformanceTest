          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="false">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
import java.io.BufferedWriter
import java.io.FileWriter
import java.io.File

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

def filePath = &quot;C:/Users/admin/Documents/Dialysis_Details/PMJAY_Dialysis_Data.csv&quot;
def file = new File(filePath)

// Create file and write header only once
if (!file.exists()) {
    file.createNewFile()

    BufferedWriter headerWriter = new BufferedWriter(new FileWriter(file))
    headerWriter.write(&quot;District_Name,Benificiary_Mobile,Facility_id,Patient_PMJAY_ID,State_Name,Abha_Id,Dialysis_datetime,Dialysis_Type,Patient_Name&quot;)
    headerWriter.newLine()
    headerWriter.close()
}

// Append records
BufferedWriter writer = new BufferedWriter(new FileWriter(file, true))

json.data.each { row -&gt;

    writer.write(
        &quot;\&quot;${row.District_Name ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Benificiary_Mobile ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Facility_id ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Patient_PMJAY_ID ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.State_Name ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Abha_Id ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Dialysis_datetime ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Dialysis_Type ?: &apos;&apos;}\&quot;,&quot; +
        &quot;\&quot;${row.Patient_Name ?: &apos;&apos;}\&quot;&quot;
    )

    writer.newLine()
}

writer.flush()
writer.close()

log.info(&quot;Successfully exported ${json.data.size()} records to ${filePath}&quot;)</stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="false">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper
import java.io.BufferedWriter
import java.io.FileWriter
import java.io.File

def targetDistrict = vars.get(&quot;DistrictFilter&quot;)

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response

)// Capture API response time
def responseTime = prev.getTime()

def filePath = &quot;C:/Users/admin/Documents/Dialysis_Details/${targetDistrict}_Dialysis_Data.csv&quot;
def file = new File(filePath)

// Create file and header
if (!file.exists()) {
    file.createNewFile()

    BufferedWriter headerWriter = new BufferedWriter(new FileWriter(file))
    headerWriter.write(&quot;District_Name,Benificiary_Mobile,Facility_id,Patient_PMJAY_ID,State_Name,Abha_Id,Dialysis_datetime,Dialysis_Type,Patient_Name,Response_Time_ms&quot;)
    headerWriter.newLine()
    headerWriter.close()
}

BufferedWriter writer = new BufferedWriter(new FileWriter(file, true))

int totalRecords = 0
int matchedRecords = 0

json.data.each { row -&gt;

    totalRecords++

    // Debug - print all district/state values
    log.info(&quot;District = [${row.District_Name}] | State = [${row.State_Name}]&quot;)

    // Filter for PULWAMA
    if (row.District_Name != null &amp;&amp;
        row.District_Name.toString().trim().equalsIgnoreCase(targetDistrict)) {

        matchedRecords++

       writer.write(
    &quot;\&quot;${row.District_Name ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Benificiary_Mobile ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Facility_id ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Patient_PMJAY_ID ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.State_Name ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Abha_Id ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Dialysis_datetime ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Dialysis_Type ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${row.Patient_Name ?: &apos;&apos;}\&quot;,&quot; +
    &quot;\&quot;${responseTime}\&quot;&quot;
        )
        writer.newLine()
    }
}

writer.flush()
writer.close()

log.info(&quot;===================================&quot;)
log.info(&quot;Total Records = &quot; + totalRecords)
log.info(&quot;Matched Records = &quot; + matchedRecords)
log.info(&quot;CSV File = &quot; + filePath)
log.info(&quot;===================================&quot;)
log.info(&quot;Total Records Received: ${totalRecords}&quot;)
log.info(&quot;Matching Records: ${matchedRecords}&quot;)
log.info(&quot;Success Rate: ${(matchedRecords * 100.0 / totalRecords).round(2)}%&quot;)</stringProp>
          </JSR223PostProcessor>
